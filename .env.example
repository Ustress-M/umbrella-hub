# ──────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# https://neon.tech 에서 프로젝트 생성 후 복사
#
# - DATABASE_URL : 앱 런타임용 (pooled, 호스트명에 -pooler 포함)
# - DIRECT_URL   : Prisma CLI migrate/introspect 용 (direct, -pooler 없음)
#   Neon Dashboard > Connection Details > "Direct connection" 으로 토글하여 복사.
#   로컬 Postgres 처럼 pooler 가 없는 환경이면 DIRECT_URL 을 비워두거나 동일 값으로 둬도 됨.
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/umbrella?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/umbrella?sslmode=require&connect_timeout=15"
# (선택) 앱 런타임 node-pg 풀 — Neon 유휴 후 첫 요청·관리자 목록 로딩 안정화
# PG_POOL_MAX=10
# PG_CONNECTION_TIMEOUT_MS=20000

# ──────────────────────────────────────────────
# CLOUDFLARE R2 (파일 저장)
# Cloudflare 대시보드 > R2 > 버킷 생성 후 API 토큰 발급
# ──────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="umbrella-returns"
# R2 버킷의 공개 URL (선택: 커스텀 도메인 또는 r2.dev 서브도메인)
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ──────────────────────────────────────────────
# NEXTAUTH.JS (관리자 인증)
# openssl rand -base64 32 로 생성
# ──────────────────────────────────────────────
AUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://your-domain.com"

# ──────────────────────────────────────────────
# 관리자 계정 (bcrypt 해시)
# 아래 명령으로 해시 생성:
#   node -e "const b=require('bcryptjs');console.log(b.hashSync('your-password',12))"
#
# ⚠️ 파일에 따라 이스케이프 규칙이 다름:
#
#   - 로컬 개발 `.env` / `.env.local` (npm run dev, @next/env 파서)
#       → $ 를 \$ 로 이스케이프 해야 함 (그렇지 않으면 변수치환됨)
#       → 예) ADMIN_PASSWORD_HASH="\$2b\$12\$MpGc9...."
#
#   - VPS `/opt/umbrella-hub/.env.production` (Docker Compose env_file)
#       → 이스케이프 금지, 따옴표 금지. 해시를 그대로 넣음.
#       → 예) ADMIN_PASSWORD_HASH=$2b$12$MpGc9....
#
#   잘못 섞어 넣으면 bcrypt.compare() 가 늘 실패해서 로그인이 안 됨.
#   컨테이너에서 실제 값 확인:
#     docker exec umbrella-hub sh -c 'echo "$ADMIN_PASSWORD_HASH" | head -c 40'
# ──────────────────────────────────────────────
ADMIN_ID="sannamgo"
ADMIN_PASSWORD_HASH="\$2b\$12\$..."

# ──────────────────────────────────────────────
# 앱 설정
# ──────────────────────────────────────────────
DELETE_AFTER_DAYS="7"
MAX_UPLOAD_SIZE_MB="5"

# ──────────────────────────────────────────────
# CRON 보안 토큰 (자동 삭제 API 보호)
# openssl rand -hex 32 로 생성
# ──────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"
