# ──────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# https://neon.tech 에서 프로젝트 생성 후 복사
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/umbrella?sslmode=require"

# ──────────────────────────────────────────────
# CLOUDFLARE R2 (파일 저장)
# Cloudflare 대시보드 > R2 > 버킷 생성 후 API 토큰 발급
# ──────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="umbrella-returns"
# R2 버킷의 공개 URL (선택: 커스텀 도메인 또는 r2.dev 서브도메인)
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ──────────────────────────────────────────────
# NEXTAUTH.JS (관리자 인증)
# openssl rand -base64 32 로 생성
# ──────────────────────────────────────────────
AUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://your-domain.com"

# ──────────────────────────────────────────────
# 관리자 계정 (bcrypt 해시)
# 아래 명령으로 해시 생성:
#   node -e "const b=require('bcryptjs');console.log(b.hashSync('your-password',12))"
# ⚠️ Next.js(@next/env)는 큰/작은따옴표 상관없이 $를 변수치환합니다.
#    bcrypt 해시의 $ 는 반드시 \$ 로 이스케이프하세요.
#    예) ADMIN_PASSWORD_HASH="\$2b\$12\$MpGc9...."
# ──────────────────────────────────────────────
ADMIN_ID="sannamgo"
ADMIN_PASSWORD_HASH="\$2b\$12\$..."

# ──────────────────────────────────────────────
# 앱 설정
# ──────────────────────────────────────────────
DELETE_AFTER_DAYS="7"
MAX_UPLOAD_SIZE_MB="5"

# ──────────────────────────────────────────────
# CRON 보안 토큰 (자동 삭제 API 보호)
# openssl rand -hex 32 로 생성
# ──────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"
